# InsureAgent — copy to .env and fill in the keys you need.
# Only the provider that matches your default model is strictly required.

# === LLM API keys (one or more) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=

# === Optional: override default model / provider ===
# DEFAULT_MODEL_PROVIDER=anthropic
# DEFAULT_MODEL=claude-sonnet-4-20250514

# === Optional: custom endpoints (proxies, OpenRouter, etc.) ===
# ANTHROPIC_BASE_URL=
# OPENAI_BASE_URL=

# === Server ===
INSURE_AGENT_PORT=7008
INSURE_AGENT_HOST=0.0.0.0
INSURE_AGENT_DB_PATH=/home/jack/insure-agent/data/insure-agent.db

# === Auth (optional — set to require Bearer token on /api/*) ===
# INSURE_AGENT_API_KEY=

# === AMS domain ===
AMS_JURISDICTION=HK

# === Safety limits ===
MAX_ITERATIONS=20
MAX_CONSECUTIVE_FAILS=5
AUTO_FIX=true
REQUIRE_APPROVAL_AFTER=10
RATE_LIMIT=60
