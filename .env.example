# InsureAgent — copy to .env and fill in the keys you need.
# Only the provider that matches your default model is strictly required.

# === LLM API keys (one or more) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
ZHIPU_API_KEY=

# === GitHub Copilot ===
# No key here — run `insure-agent auth login` once to OAuth.
# The GH token is cached in ~/.config/insure-agent/copilot.json
# and exchanged for a short-lived Copilot bearer on each request.

# === Optional: override default model / provider ===
# DEFAULT_MODEL_PROVIDER=zhipu     # anthropic | openai | google | deepseek | zhipu | copilot
# DEFAULT_MODEL=glm-5.1            # e.g. claude-sonnet-4, gpt-4.1, gemini-2.5-pro, glm-5.1

# === Optional: custom endpoints (proxies, OpenRouter, etc.) ===
# ANTHROPIC_BASE_URL=
# OPENAI_BASE_URL=
# ZHIPU_BASE_URL=

# === Server ===
INSURE_AGENT_PORT=7008
INSURE_AGENT_HOST=0.0.0.0
INSURE_AGENT_DB_PATH=/home/jack/insure-agent/data/insure-agent.db

# === Auth (optional — set to require Bearer token on /api/*) ===
# INSURE_AGENT_API_KEY=

# === AMS domain ===
AMS_JURISDICTION=HK

# === Safety limits ===
MAX_ITERATIONS=20
MAX_CONSECUTIVE_FAILS=5
AUTO_FIX=true
REQUIRE_APPROVAL_AFTER=10
RATE_LIMIT=60
